<Window x:Class="LyricDock.Windows.Views.LyricBarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:LyricDock.Windows.Controls"
        Title="LyricDock"
        Width="500"
        Height="44"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        MouseLeftButtonDown="OnMouseLeftButtonDown"
        MouseLeftButtonUp="OnMouseLeftButtonUp"
        MouseMove="OnMouseMove"
        LocationChanged="OnLocationChanged"
        Loaded="OnLoaded"
        Closing="OnClosing">

    <Border x:Name="MainBorder"
            CornerRadius="8"
            Margin="0,2,0,2"
            Padding="8,4,8,4"
            SnapsToDevicePixels="True">
        <Border.Background>
            <SolidColorBrush x:Name="BarBackground" Color="#E0E0E0" Opacity="0.88"/>
        </Border.Background>
        <Border.BorderBrush>
            <SolidColorBrush Color="#40000000"/>
        </Border.BorderBrush>
        <Border.BorderThickness>1</Border.BorderThickness>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="32"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 封面 -->
            <Border Grid.Column="0"
                    Width="28" Height="28"
                    CornerRadius="6"
                    ClipToBounds="True"
                    Background="#18FFFFFF"
                    MouseLeftButtonDown="OnArtworkClick">
                <Border.BorderBrush>
                    <SolidColorBrush Color="#33FFFFFF"/>
                </Border.BorderBrush>
                <Border.BorderThickness>0.5</Border.BorderThickness>
                <Grid>
                    <Image x:Name="ArtworkImage"
                           Stretch="UniformToFill"
                           Visibility="Collapsed"/>
                    <TextBlock x:Name="MusicIcon"
                               Text="🎵"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- 歌词滚动文字 -->
            <Grid Grid.Column="1" Margin="6,0,6,0" VerticalAlignment="Center">
                <ctrl:ScrollingTextBlock x:Name="LyricText"
                                         Text="等待播放"
                                         FontSize="13"
                                         FontWeight="Bold"
                                         FontFamily="Microsoft YaHei UI"
                                         Foreground="#E0000000"
                                         ScrollWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Grid}}"/>
            </Grid>

            <!-- 播放控制按钮 -->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="2,0,0,0">

                <!-- 上一首 -->
                <Button x:Name="PrevButton"
                        Click="OnPreviousClick"
                        Width="24" Height="24"
                        Cursor="Hand"
                        ToolTip="上一首">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" CornerRadius="5" Background="#14FFFFFF">
                                <Path Data="M5,2 L0,7.5 L5,13 M12,2 L7,7.5 L12,13"
                                      Stroke="#E0000000" StrokeThickness="1.5"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Margin="0,0,0,0"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#28FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#38FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- 播放/暂停 -->
                <Button x:Name="PlayPauseButton"
                        Click="OnPlayPauseClick"
                        Width="26" Height="26"
                        Cursor="Hand"
                        Margin="3,0,3,0"
                        ToolTip="播放">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" CornerRadius="6" Background="#D4F5D45A">
                                <Path x:Name="Icon" Data="M4,2 L4,14 L14,8 Z"
                                      Fill="#D9000000" Stretch="Uniform"
                                      Width="10" Height="10"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#E8F5D45A"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#C0F5D45A"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- 下一首 -->
                <Button x:Name="NextButton"
                        Click="OnNextClick"
                        Width="24" Height="24"
                        Cursor="Hand"
                        ToolTip="下一首">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" CornerRadius="5" Background="#14FFFFFF">
                                <Path Data="M0,2 L5,7.5 L0,13 M7,2 L12,7.5 L7,13"
                                      Stroke="#E0000000" StrokeThickness="1.5"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#28FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#38FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
